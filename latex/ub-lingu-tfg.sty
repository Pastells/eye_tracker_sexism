\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ub-lingu-tfg}[2025/10/17 UB TFG style]

\usepackage[a4paper,margin=2.5cm]{geometry} % marges uniformes 2,5 cm
\usepackage{setspace}  % paquet per interlineat
\setstretch{1.5} % interlineat 1,5

% --- Paquets ---
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage[english, catalan]{babel}
\RequirePackage{graphicx}
\RequirePackage{geometry}
\RequirePackage{setspace}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{hyperref}
\RequirePackage{xcolor}
\RequirePackage{caption}
\usepackage{titlesec} % format dels títols

\usepackage{pdfpages} % per afegir el PDF de l'autoria

% --- Bibliografia ---

 % fem servir aquest perquè vull la secció de la bibliografia numerada i poder escollir el seu títol
\usepackage[style=apa,backend=biber]{biblatex}
\addbibresource{main.bib} % provide actual file name


% --- Colors institucionals UB ---
\usepackage{xcolor}
\definecolor{ubblue}{RGB}{0,51,153} % només per logotips, títols destacats




% --- Capçalera i peu de pàgina ---
% --- Assegurar fancyhdr a tot el document ---
\pagestyle{fancy}
\fancypagestyle{plain}{%
  \fancyhf{} % neteja
  \fancyhead[L]{\textit{Treball de Fi de Grau}}
  \fancyhead[R]{\leftmark}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0.4pt}
  \renewcommand{\footrulewidth}{0pt}
}


% --- Títols de secció ---
% --- Format dels títols ---

% Capítols (nivell 0)
\titleformat{\chapter}[hang]{\bfseries\LARGE}{\thechapter.}{1em}{}
\titlespacing*{\chapter}{0pt}{-0.5em}{1em} % menys espai abans del títol

% Seccions (nivell 1)
\titleformat{\section}[hang]{\bfseries\large}{\thesection.}{1em}{}
\titlespacing*{\section}{0pt}{2em}{1em} % controla espai abans/després

% Subseccions (nivell 2)
\titleformat{\subsection}[hang]{\bfseries\normalsize}{\thesubsection.}{1em}{}
\titlespacing*{\subsection}{0pt}{0.75em}{0.3em}


% --- Figures ---
\captionsetup{
  font=small,
  labelfont=bf,
  labelsep=period,
  textfont=it,
  width=0.9\textwidth,
  justification=centering
}

\newcommand{\ubfigure}[3][]{%
  \begin{figure}[h!]
    \centering
    \includegraphics[width=0.8\textwidth]{#2}
    \caption{#3}
    \label{#1}
  \end{figure}
}



% --- Taules ---
\usepackage{booktabs} % línies més netes
\usepackage{array}
\usepackage{caption}

% Configuració general de les taules
\captionsetup[table]{
  font=small,
  labelfont=bf,
  labelsep=period,
  textfont=it,
  width=0.9\textwidth,
  justification=centering
}

% Comanda per inserir taules UB
% Ús: \ubtable{etiqueta}{caption}{cos de la taula}
\newcommand{\ubtable}[3]{%
  \begin{table}[h!]
    \centering
    \renewcommand{\arraystretch}{1.3} % espai entre files
    #3
    \caption{#2}
    \label{#1}
  \end{table}
}







% --- Configuració de PDF ---
\hypersetup{
  colorlinks=true,
  linkcolor=ubblue,
  urlcolor=ubblue,
  citecolor=ubblue,
  pdfsubject={Treball de Fi de Grau, Universitat de Barcelona},
  pdfkeywords={TFG, Universitat de Barcelona, Lingüística, Recerca}
}

\endinput
